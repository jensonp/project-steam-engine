{
  "name": "steam-recommender-backend",
  "version": "1.0.0",
  "description": "Steam Game Recommendation API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "data:download": "ts-node src/scripts/download-dataset.ts",
    "data:process": "ts-node src/scripts/process-dataset.ts",
    "data:build-recommender": "ts-node src/scripts/build-recommender.ts",
    "data:pipeline": "npm run data:process && npm run data:build-recommender",
    "data:inspect-csv": "ts-node src/scripts/inspect-csv-columns.ts"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
